# URL publique du site (optionnel mais recommandé en prod) — Open Graph / metadataBase
# Ex. https://paye-ta-graille.vercel.app ou ton domaine custom
# NEXT_PUBLIC_SITE_URL=

# Supabase (https://supabase.com/dashboard) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Auth → URL Configuration : ajouter http://localhost:3000/auth/callback (et l’URL prod) dans Redirect URLs.

# Server only — never expose to client. Admin / migrations + webhook Stripe (mise à jour payment_ledger).
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe (paiement repas) — https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=
# Webhook signing secret — https://dashboard.stripe.com/webhooks (endpoint /api/stripe/webhook)
# STRIPE_WEBHOOK_SECRET=

# Email (https://resend.com) — after MVP notifications
# RESEND_API_KEY=

# Google Places (legacy JSON API) — server only, never NEXT_PUBLIC_
# Active Places API + billing ; utilisé pour : /api/places/search, autocomplete, details, nearby
# GOOGLE_PLACES_API_KEY=

# Carte dans l’app (navigateur) — Maps JavaScript API, clé restreinte par référent HTTP
# Même projet Google Cloud possible ; souvent une 2e clé « client » plus sûre que réutiliser la clé serveur
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: copy UX variante B — `src/lib/ux-variant.ts`
# NEXT_PUBLIC_PTG_UX_VARIANT=b

# Optional: bandeau « version bêta » + noindex SEO — `BetaBanner`, `layout` metadata
# NEXT_PUBLIC_PTG_PUBLIC_BETA=1

# Optional: Sentry, analytics (post-MVP)
# SENTRY_DSN=

# Optional: modules produit « Graille+ » — 1 ou true pour activer ; absent ou 0 = V1 seule (pas d’entrée nav dédiée)
# NEXT_PUBLIC_PTG_MODULE_SHARE=
# NEXT_PUBLIC_PTG_MODULE_FOOD_RESCUE=
# NEXT_PUBLIC_PTG_MODULE_PAYMENTS=

# Server only — modules Graille+ : exiger email_confirmed_at (Supabase). Mettre 0 ou false pour désactiver (dev / cas OAuth).
# Défaut : exigence active. Le profil (pseudo + ville) reste toujours requis.
# PTG_MODULE_REQUIRE_VERIFIED_EMAIL=

# « Surprise graille » sur Rencontres — 0 ou false pour masquer ; absent = activé
# NEXT_PUBLIC_PTG_SURPRISE_GRAILLE=
