# URL publique du site (optionnel mais recommandé en prod) : Open Graph / metadataBase
# Ex. https://paye-ta-graille.vercel.app ou ton domaine custom
# NEXT_PUBLIC_SITE_URL=

# Supabase (https://supabase.com/dashboard) : Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Auth → URL Configuration : ajouter les Redirect URLs (chaque origine utilisée) :
#   http://localhost:3000/auth/callback  et si le dev écoute sur 3001 : http://localhost:3001/auth/callback
#   + https://<preview>.vercel.app/auth/callback + https://<prod>/auth/callback

# Next.js dev : accès téléphone / LAN sur `/_next/*` (allowedDevOrigins). Par défaut les IPv4 locales sont détectées.
# NEXT_DEV_DISCOVER_LAN=0
# Hôtes supplémentaires (sans http), ex. : NEXT_DEV_ALLOWED_ORIGINS=192.168.1.35,10.0.0.12

# Server only : never expose to client. Admin / migrations + webhook Stripe (mise à jour payment_ledger).
# SUPABASE_SERVICE_ROLE_KEY=
#
# Après mise à jour du code : appliquer supabase/migrations/*.sql sur le projet distant (supabase db push, link, ou SQL Editor).
# Inclut notamment auto_complete_confirmed_meals (clôture cron) : voir 20260430200000_auto_complete_meals_rpc.sql.

# Rate limit distribué (recommandé prod multi-instance) : Upstash Redis REST
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Stripe (paiement repas) : https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=
# Webhook signing secret : https://dashboard.stripe.com/webhooks (endpoint /api/stripe/webhook)
# STRIPE_WEBHOOK_SECRET=

# Email (https://resend.com) : ex. notification « repas proposé » (respecte nudge off + silence nocturne invité)
# En prod : combiner avec SUPABASE_SERVICE_ROLE_KEY (RPC quota e-mail + lecture e-mail invité).
# RESEND_API_KEY=
# Expéditeur vérifié sur Resend (prod) ; sinon domaine de test Resend
# RESEND_FROM_EMAIL=Paye ta graille <onboarding@resend.dev>

# Cron Vercel : rappels repas J-24 / J-2h + clôture auto `confirmed` → `completed` après créneau (`GET /api/cron/meal-reminders`, `vercel.json`). Vercel envoie `Authorization: Bearer <CRON_SECRET>` si défini.
# CRON_SECRET=
# Déclenchement manuel (serveur déjà lancé) : PTG_BASE_URL=http://127.0.0.1:3000 CRON_SECRET=… npm run cron:meal-reminders
# Clôture auto : heures après fin de fenêtre (max(window_start, window_end)) ; défaut 24. Désactiver : PTG_MEAL_AUTO_COMPLETE=off
# PTG_MEAL_AUTO_COMPLETE_GRACE_HOURS=24
# PTG_MEAL_AUTO_COMPLETE=

# Google Places (legacy JSON API) : server only, never NEXT_PUBLIC_
# Active Places API + billing ; utilisé pour : /api/places/search, autocomplete, details, nearby
# GOOGLE_PLACES_API_KEY=

# Carte dans l’app (navigateur) : Maps JavaScript API, clé restreinte par référent HTTP
# Même projet Google Cloud possible ; souvent une 2e clé « client » plus sûre que réutiliser la clé serveur
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Local uniquement : `npm run deploy:preflight` sans clés Google (avertissement affiché ; Lieux limités)
# PTG_PREFLIGHT_ALLOW_MISSING_PLACES=1

# Optional: copy UX variante B : `src/lib/ux-variant.ts`
# NEXT_PUBLIC_PTG_UX_VARIANT=b

# Optional: bandeau « version bêta » + noindex + robots/sitemap fermés : `BetaBanner`, `layout`, `robots.ts`, `sitemap.ts`
# NEXT_PUBLIC_PTG_PUBLIC_BETA=1

# Optional: Sentry, analytics (post-MVP)
# SENTRY_DSN=

# Optional: modules produit « Graille+ » : 1 ou true pour activer ; absent ou 0 = V1 seule (pas d’entrée nav dédiée)
# NEXT_PUBLIC_PTG_MODULE_SHARE=
# NEXT_PUBLIC_PTG_MODULE_FOOD_RESCUE=
# NEXT_PUBLIC_PTG_MODULE_PAYMENTS=

# Server only : modules Graille+ : exiger email_confirmed_at (Supabase). Mettre 0 ou false pour désactiver (dev / cas OAuth).
# Défaut : exigence active. Le profil (pseudo + ville) reste toujours requis.
# PTG_MODULE_REQUIRE_VERIFIED_EMAIL=

# « Surprise graille » sur Rencontres : 0 ou false pour masquer ; absent = activé
# NEXT_PUBLIC_PTG_SURPRISE_GRAILLE=

# URLs d’images distantes : liste des clés dans `config/public-hero-image-url-env-keys.json` (remotePatterns Next + preflight).
#
# Illustration hero (accueil) : défaut = `public/hero/landing-watercolor.webp` (généré depuis le PNG ci-dessous).
# Variantes optionnelles : placer `landing-watercolor-night.png`, `-mobile.png`, `-night-mobile.png` dans public/hero/
# puis npm run optimize:hero (ignore les PNG absents). Fichiers WebP : landing-watercolor-night.webp, etc.
# Remplacer le PNG puis : npm run optimize:hero (WebP, largeur max 1920px pour le LCP).
# URL absolue alternative (voir next.config `images.remotePatterns`) :
# NEXT_PUBLIC_PTG_HERO_ART=

# Recadrage mobile optionnel (hero) : élément picture sous 640px ; absent = une seule image.
# Ex. : /hero/landing-watercolor-mobile.webp
# NEXT_PUBLIC_PTG_HERO_ART_MOBILE=

# Bandeau « nuit » (Partenaires, Expériences…) : cadre CSS ratio 3:2 — image **3:2** (ex. 1200×800) = pas de bandes.
# WebP plus sombre / autre cadrage. Absent = même URL que le hero.
# Ex. après optimize:hero avec landing-watercolor-night.png : /hero/landing-watercolor-night.webp
# NEXT_PUBLIC_PTG_HERO_ART_NIGHT=

# Recadrage mobile optionnel pour le bandeau nuit ; absent = pas de source séparée (URL `…_NIGHT` ou hero).
# NEXT_PUBLIC_PTG_HERO_ART_NIGHT_MOBILE=

# Fond illustré « marque » (page À propos) : défaut `public/hero/brand-marketplace.webp` (`brand-marketplace.png` + `npm run optimize:hero`).
# Affiche optionnelle : `brand-poster.webp` si tu mets `brand-poster.png` puis optimize:hero, puis ex. NEXT_PUBLIC_PTG_HERO_ART_BRAND=/hero/brand-poster.webp
# NEXT_PUBLIC_PTG_HERO_ART_BRAND=
# NEXT_PUBLIC_PTG_HERO_ART_BRAND_MOBILE=
# Page livret « L’univers en une image » : défaut `/hero/brand-poster.png` ; WebP léger après optimize:hero : `/hero/brand-poster.webp`
# NEXT_PUBLIC_PTG_ABOUT_LIVRET_POSTER=

# Désactiver l’illustration (0 / false / off) si pas d’asset : voir `src/lib/env-public.ts`
# NEXT_PUBLIC_PTG_HERO_ILLUSTRATION=

# Cadre illustration « marque » en bas de page À propos : indépendant de NEXT_PUBLIC_PTG_HERO_ILLUSTRATION. Désactiver : 0 / false / off
# NEXT_PUBLIC_PTG_HERO_BRAND_DECOR=

# Image Open Graph / Twitter (carte de partage), optionnelle : ex. 1200×630 WebP sous public/…
# Absent = même URL que le hero (`NEXT_PUBLIC_PTG_HERO_ART` ou défaut `landing-watercolor.webp`).
# Ex. carte depuis affiche : `/og/paye-ta-graille-share.webp` après optimize:hero si `brand-poster.png` est présent.
# NEXT_PUBLIC_PTG_OG_IMAGE=

# Dev : autoriser l’accès Next depuis un autre appareil sur le LAN (sans http), cf. doc Next `allowedDevOrigins`
# NEXT_DEV_ALLOWED_ORIGINS=

# KPI croissance (interne) : `GET /api/growth/kpi` + page `/interne/croissance` (noindex)
# Liste d’UUID Supabase (créateur) autorisés à voir le tableau de bord sans secret :
# PTG_GROWTH_ADMIN_USER_IDS=
# Secret optionnel pour scripts / outils (en-tête x-ptg-growth-kpi-secret) :
# PTG_GROWTH_KPI_SECRET=

# Notifications et rythme utilisateur (valeurs stockées par utilisateur via /api/profile)
# nudge_level: calme | normal | off
# nudge_quiet_start_hour: heure silence début (0-23, défaut 22)
# nudge_quiet_end_hour: heure silence fin (0-23, défaut 8)
# nudge_max_per_day: plafond journalier (0-6, défaut 1)

# Scripts smoke, wait:health, assert-beta-seo : base HTTP (défaut http://127.0.0.1:3000 ; évite soucis IPv6/localhost)
# PTG_BASE_URL=
# Port pour `npm run checks:prod-local` si 3000 est déjà pris (`next start -p …`)
# PTG_CHECK_PORT=3010

# Playwright : ne pas lancer `next start` via webServer (serveur déjà actif, ou autre PTG_BASE_URL)
# PTG_PLAYWRIGHT_NO_WEBSERVER=1
# Inclus automatiquement par `npm run test:e2e:beta-seo` : inclut `e2e/beta-seo.spec.ts` (sinon ignoré par `test:e2e`)
# PTG_RUN_BETA_E2E=1

# Preflight déploiement : 1 / true pour warnings détaillés (hero URL distante, etc.) : npm run deploy:preflight
# PTG_VERBOSE_PREFLIGHT=

# CSP (sécurité navigateur) : report-only par défaut pour rollout progressif
# PTG_CSP_REPORT_ONLY=1
# Endpoint optionnel de collecte des rapports CSP (Sentry/collector)
# PTG_CSP_REPORT_URI=
